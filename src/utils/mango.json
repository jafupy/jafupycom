{
  "scopeName": "source.mango",
  "displayName": "Mango",
  "name": "mango",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#arithmetic"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line",
          "match": "//.*$"
        },
        {
          "name": "comment.block",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control",
          "match": "\\b(if|else|for|while)\\b"
        },
        {
          "name": "keyword.variable",
          "match": "\\b(var|const)\\b"
        },
        {
          "name": "keyword.muted",
          "match": "\\b(mut)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator",
          "match": "\\+|\\-|\\*|\\/|\\%|\\=|\\!|\\<|\\>|\\&|\\||\\^"
        },
        {
          "name": "punctuation.separator",
          "match": "\\,|\\;|\\."
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "arithmetic": {
      "patterns": [
        {
          "name": "expression.arithmetic",
          "match": "\\b[0-9]+\\s*[-+*/%]\\s*[0-9]+\\b"
        }
      ]
    }
  }
}
